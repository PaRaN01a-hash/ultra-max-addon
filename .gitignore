cd /home/ubuntu/stremio-catalog-addon

cat > .gitignore <<'EOF'
# Secrets
.env
.env.*
!.env.example

# Runtime data
configs.json

# Node
node_modules/

# Logs
*.log
webhook.log

# Backups
*.bak*
*.GOLDEN*
*.tar.gz
archive-backups/
old-dev-backups-*/

# Generated exports
*.json
!package.json
!package-lock.json

# Dev-only files
index-dev.js
configure-dev.html
configure-v2.html
collections-builder.html
check-ultramax.sh
deploy-ultramax.sh
rollback-ultramax.sh

# OS/editor
.DS_Store
Thumbs.db
.vscode/
EOF
